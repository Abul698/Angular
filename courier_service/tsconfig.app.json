{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "rootDir": "src"
  },
  "include": [
    "src/**/*.ts"  // এখানে .d.ts এর বদলে শুধু .ts দিন অথবা নিচের মতো সব ফাইল ধরুন
  ],
  "exclude": [
    "src/test.ts",
    "src/**/*.spec.ts"
  ]
}